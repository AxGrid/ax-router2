# =============================================================================
# ax-router2 — server configuration
# Copy this file to `.env` and edit. The binary loads it via -env flag.
# =============================================================================

# --- Public listeners --------------------------------------------------------

# Plain HTTP listener (browser-facing). Behind a TLS terminator (nginx/caddy)
# this is usually fine.
AXR_PUBLIC_ADDR=:80

# Optional HTTPS listener. Empty = disabled. Required to be set if AXR_TLS_MODE
# is anything other than "off".
AXR_PUBLIC_TLS_ADDR=

# When true, every plain-HTTP request is 301-redirected to its HTTPS twin.
# ACME HTTP-01 challenges and the "Issuing certificate" loading page are
# exempted automatically. No-op unless AXR_PUBLIC_TLS_ADDR is set and
# AXR_TLS_MODE is non-off.
AXR_HTTPS_REDIRECT=false

# --- Routing -----------------------------------------------------------------

# Base domain (apex). The apex itself is reserved for the dashboard and cannot
# be claimed by any service. Service name is the last subdomain label after
# stripping ".<AXR_BASE_DOMAIN>".
#   Example: "api.foo.router.com" → service "foo".
AXR_BASE_DOMAIN=router.com

# How long to hold a request waiting for a recently-disconnected client to
# come back. Smooths over service restarts before falling through to 502.
AXR_RECONNECT_GRACE=3s

# --- Control listener (where router-clients connect) ------------------------

AXR_CONTROL_ADDR=:7000

# --- Tokens -----------------------------------------------------------------

# A token may be bound to a specific service ("foo") or "*" for any service
# name supplied by the client in its Hello frame.
#
# Inline form: comma-separated "token:service" pairs.
# AXR_TOKENS=globalsecret:*
# AXR_TOKENS=admin:*,fixed-tok:foo

# JSON file: { "globalsecret": "*", "fixed-tok": "foo" }
# Watched by fsnotify + SIGHUP for hot-reload.
# AXR_TOKENS_FILE=./tokens.json

# --- Admin dashboard --------------------------------------------------------

# If both are set, the apex (router.com) and /__router/* endpoints are gated
# by HTTP basic auth. Leave empty to expose the dashboard publicly.
AXR_ADMIN_USER=
AXR_ADMIN_PASS=

# =============================================================================
# TLS — choose one mode
# =============================================================================

# Modes:
#   off       — no TLS on this server (terminate elsewhere).
#   file      — load cert/key from disk (typically a wildcard).
#   autocert  — Let's Encrypt via HTTP-01/TLS-ALPN-01.
#               Wildcards NOT supported by these challenges; list explicit hosts.
#   dns       — Let's Encrypt via DNS-01 with a libdns provider.
#               Supports wildcards AND on-demand multi-level certs. See section
#               "Wildcard certificate" in README for details.
AXR_TLS_MODE=off

# --- Mode: file -------------------------------------------------------------
AXR_TLS_CERT_FILE=
AXR_TLS_KEY_FILE=

# --- Mode: autocert ---------------------------------------------------------
# AUTOCERT_DOMAINS is OPTIONAL — leave empty to rely entirely on dynamic
# per-service issuance (a cert is provisioned for "<service>.<base>" the
# moment the service connects). Use this list only if you also want to
# pre-issue/whitelist extra hostnames (e.g. a custom landing-page host).
AXR_TLS_AUTOCERT_DOMAINS=
AXR_TLS_AUTOCERT_EMAIL=
AXR_TLS_AUTOCERT_CACHE=./autocert-cache

# --- Mode: dns (DNS-01) -----------------------------------------------------
# Currently supported provider: digitalocean.
AXR_DNS_PROVIDER=
AXR_ACME_EMAIL=
AXR_ACME_CACHE=./acme-cache
# Optional: pre-issue a list of certs at startup. Empty = on-demand only,
# certs issued lazily on first TLS handshake for any host under base domain.
# AXR_ACME_DOMAINS=*.router.com,router.com
# Optional: switch to LE staging (no rate limits but untrusted certs).
# AXR_ACME_STAGING=true
# Provider credentials (env-var name expected by the provider).
DIGITALOCEAN_TOKEN=
